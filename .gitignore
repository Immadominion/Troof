# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- Troof: AI/agent tooling + internal planning docs (never push) ---
.claude/
.gemini/
.agents/
.superstack/
.cursor/
.brand-preview/
AGENTS.md
CLAUDE.md
STRATEGY.md
context.txt

# Move build artifacts (keep the source, not the compiled output)
/move/*/build/

# keep the env TEMPLATE even though the .env* rule above ignores all env files
!.env.example

# Font source archive (extracted into src/app/fonts)
clash-display-font.zip

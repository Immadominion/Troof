    { "id": "engine", "label": "Report + Troof Score\n(/lib report·token·score)", "lane": "Troof server (Next.js)" },
    { "id": "seal", "label": "Seal\n(/lib/seal)", "lane": "Troof server (Next.js)" },
    { "id": "tatum", "label": "Tatum\nSui RPC · Exchange-Rate · MCP", "lane": "External networks", "tag": "Tatum" },

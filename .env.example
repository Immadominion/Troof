# Troof — environment. Copy to .env.local for dev; set the same keys in Vercel for prod.

# Tatum API key (free at dashboard.tatum.io) — powers Sui RPC + Exchange-Rate + the MCP server.
TATUM_API_KEY=

# Anthropic key — powers the Troof agent (Claude via AI SDK).
ANTHROPIC_API_KEY=

# Server signer for the on-chain anchor (bech32 suiprivkey…). Generated by scripts/deploy-anchor.mjs.
# Must be funded on TROOF_ANCHOR_NETWORK (testnet faucet, or real SUI for mainnet).
TROOF_SIGNER_KEY=

# The published troof_anchor Move package id (written by scripts/deploy-anchor.mjs).
TROOF_ANCHOR_PACKAGE=

# Where proofs are anchored + stored: "testnet" (dev) or "mainnet" (prod bonus).
TROOF_ANCHOR_NETWORK=testnet

# On serverless (Vercel) the stdio Tatum MCP can't be spawned — set to 1 to skip it and
# use the local Tatum-engine tools instead. Leave unset locally to use the real MCP.
TROOF_DISABLE_MCP=

# Default Sui network the UI reads (proofs live on TROOF_ANCHOR_NETWORK).
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# x402 paid API (/api/v1/*). Leave X402_PAY_TO unset to keep the endpoints OPEN (dev/demo);
# set it to your receiving EVM address to require payment (USDC). Free testnet facilitator is used.
X402_PAY_TO=
X402_NETWORK=base-sepolia

# Chat usage gate. Free analyses before a wallet is required (limited until you connect).
NEXT_PUBLIC_FREE_ANALYSES=5
# Pay-per-use in the UI: set a Sui treasury address to charge connected users (off by default —
# unset = connecting a wallet unlocks unlimited). Price is per 20-analysis pack.
NEXT_PUBLIC_TROOF_TREASURY=
NEXT_PUBLIC_PRICE_SUI=0.1

